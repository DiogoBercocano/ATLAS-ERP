# Ignora completamente arquivos front-end da detecção de linguagem
*.html linguist-vendored=true
*.css linguist-vendored=true
*.js linguist-vendored=true
*.jsx linguist-vendored=true
*.ts linguist-vendored=true
*.tsx linguist-vendored=true
*.scss linguist-vendored=true
*.sass linguist-vendored=true
*.less linguist-vendored=true
 
# Garante que C# seja reconhecido como linguagem principal
*.cs linguist-detectable=true
*.cs linguist-language=C#
