@model List<ATLAS_ERP.Models.Empresa>
@{
    ViewBag.Title = "Super Admin - Atlas ERP";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Atlas ERP – Super Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #050d1a;
            --panel: #0b1525;
            --card: #0f1e35;
            --card-hover: #132540;
            --border: rgba(100,160,255,0.10);
            --border-md: rgba(100,160,255,0.18);
            --accent: #3b82f6;
            --accent-soft: rgba(59,130,246,0.12);
            --accent-light: #60a5fa;
            --gold: #c9a84c;
            --gold-soft: rgba(201,168,76,0.12);
            --green: #34d399;
            --green-soft: rgba(52,211,153,0.10);
            --red: #f87171;
            --red-soft: rgba(248,113,113,0.10);
            --text: #e8f0fe;
            --muted: #7a9cc8;
            --faint: #3d5270;
            --radius: 14px;
        }

        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding: 36px 40px;
            position: relative;
        }

        .bg-dots {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            background-image: radial-gradient(circle, rgba(59,130,246,0.10) 1px, transparent 1px);
            background-size: 36px 36px;
            mask-image: radial-gradient(ellipse 70% 70% at 60% 40%, black, transparent);
        }

        .content {
            position: relative;
            z-index: 1;
            max-width: 1100px;
            margin: 0 auto;
        }

        /* TOPBAR */
        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 32px;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .topbar-logo {
            width: 90px;
            filter: brightness(0) invert(1);
        }

        .page-title {
            font-family: 'Syne', sans-serif;
            font-size: 20px;
            font-weight: 700;
        }

        .page-sub {
            font-size: 12px;
            color: var(--muted);
            margin-top: 2px;
        }

        .super-badge {
            font-size: 11px;
            font-weight: 600;
            background: linear-gradient(135deg, #c9a84c, #f0c060);
            color: #0f1e35;
            padding: 4px 12px;
            border-radius: 20px;
            letter-spacing: 0.04em;
        }

        .btn-logout {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            color: var(--red);
            background: var(--red-soft);
            border: 1px solid rgba(248,113,113,0.18);
            padding: 8px 14px;
            border-radius: 8px;
            transition: background 0.18s;
        }

            .btn-logout:hover {
                background: rgba(248,113,113,0.18);
            }

            .btn-logout svg {
                width: 14px;
                height: 14px;
            }

        /* METRICAS */
        .metrics {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 28px;
            animation: fadeUp 0.5s ease both;
        }

        .metric-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px 22px;
            position: relative;
            overflow: hidden;
            transition: border-color 0.2s, transform 0.2s;
        }

            .metric-card:hover {
                border-color: var(--border-md);
                transform: translateY(-2px);
            }

            .metric-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
            }

            .metric-card.blue::before {
                background: var(--accent);
            }

            .metric-card.gold::before {
                background: var(--gold);
            }

            .metric-card.green::before {
                background: var(--green);
            }

            .metric-card.red::before {
                background: var(--red);
            }

        .metric-label {
            font-size: 11px;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 6px;
        }

        .metric-value {
            font-family: 'Syne', sans-serif;
            font-size: 28px;
            font-weight: 700;
        }

        /* TABELA */
        .table-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            animation: fadeUp 0.6s ease 0.1s both;
        }

        .table-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 24px 14px;
            border-bottom: 1px solid var(--border);
        }

        .table-title {
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            font-weight: 700;
        }

        .badge-pill {
            font-size: 11px;
            background: var(--accent-soft);
            color: var(--accent-light);
            border: 1px solid rgba(59,130,246,0.2);
            padding: 3px 10px;
            border-radius: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            font-size: 11px;
            color: var(--faint);
            text-transform: uppercase;
            letter-spacing: 0.07em;
            font-weight: 500;
            padding: 10px 20px;
            text-align: left;
            background: rgba(0,0,0,0.15);
        }

        tbody tr {
            border-top: 1px solid var(--border);
            transition: background 0.15s;
        }

            tbody tr:hover {
                background: var(--card-hover);
            }

        tbody td {
            padding: 14px 20px;
            font-size: 14px;
        }

        .td-muted {
            color: var(--muted);
            font-size: 13px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 11px;
            padding: 3px 10px;
            border-radius: 20px;
        }

            .status-badge.ativa {
                background: var(--green-soft);
                color: var(--green);
            }

            .status-badge.pendente {
                background: var(--gold-soft);
                color: var(--gold);
            }

        .status-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: currentColor;
        }

        .actions {
            display: flex;
            gap: 6px;
        }

        .btn-act {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 11px;
            font-weight: 500;
            padding: 6px 12px;
            border-radius: 7px;
            border: 1px solid;
            cursor: pointer;
            white-space: nowrap;
            transition: background 0.15s, transform 0.12s;
            background: none;
        }

            .btn-act:hover {
                transform: translateY(-1px);
            }

            .btn-act svg {
                width: 12px;
                height: 12px;
            }

        .btn-aprovar {
            border-color: rgba(52,211,153,0.25);
            color: var(--green);
            background: var(--green-soft);
        }

            .btn-aprovar:hover {
                background: rgba(52,211,153,0.18);
            }

        .btn-rejeitar {
            border-color: rgba(201,168,76,0.25);
            color: var(--gold);
            background: var(--gold-soft);
        }

            .btn-rejeitar:hover {
                background: rgba(201,168,76,0.2);
            }

        .btn-excluir {
            border-color: rgba(248,113,113,0.25);
            color: var(--red);
            background: var(--red-soft);
        }

            .btn-excluir:hover {
                background: rgba(248,113,113,0.2);
            }

        .empty-state {
            padding: 48px;
            text-align: center;
            color: var(--faint);
            font-size: 13px;
        }

        /* MODAL */
        .modal-overlay {
            position: fixed;
            inset: 0;
            z-index: 999;
            background: rgba(0,0,0,0.65);
            backdrop-filter: blur(4px);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

            .modal-overlay.open {
                display: flex;
            }

        .modal {
            background: var(--card);
            border: 1px solid var(--border-md);
            border-radius: 18px;
            padding: 32px 36px;
            width: 100%;
            max-width: 380px;
            text-align: center;
            position: relative;
            animation: fadeUp 0.25s ease both;
        }

        .modal-close {
            position: absolute;
            top: 16px;
            right: 16px;
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 8px;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--muted);
            transition: background 0.15s, color 0.15s;
        }

            .modal-close:hover {
                background: var(--red-soft);
                color: var(--red);
            }

            .modal-close svg {
                width: 14px;
                height: 14px;
            }

        .modal-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: var(--red-soft);
            border: 2px solid rgba(248,113,113,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            color: var(--red);
        }

            .modal-icon svg {
                width: 22px;
                height: 22px;
            }

        .modal-title {
            font-family: 'Syne', sans-serif;
            font-size: 17px;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .modal-sub {
            font-size: 13px;
            color: var(--muted);
            margin-bottom: 6px;
        }

        .modal-warn {
            font-size: 12px;
            color: var(--faint);
            margin-bottom: 24px;
        }

        .modal-actions {
            display: flex;
            gap: 10px;
        }

        .modal-btn-cancel {
            flex: 1;
            height: 44px;
            background: none;
            border: 1px solid var(--border);
            border-radius: 9px;
            color: var(--muted);
            font-size: 14px;
            cursor: pointer;
            transition: background 0.15s, color 0.15s;
        }

            .modal-btn-cancel:hover {
                background: var(--card-hover);
                color: var(--text);
            }

        .modal-btn-delete {
            flex: 1;
            height: 44px;
            background: var(--red);
            border: none;
            border-radius: 9px;
            font-family: 'Syne', sans-serif;
            font-size: 14px;
            font-weight: 600;
            color: white;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s;
        }

            .modal-btn-delete:hover {
                background: #ef4444;
                transform: translateY(-1px);
            }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 900px) {
            .metrics {
                grid-template-columns: repeat(2, 1fr);
            }

            body {
                padding: 20px;
            }
        }
    </style>
</head>
<body>

    <div class="bg-dots"></div>

    <div class="content">

        <div class="topbar">
            <div class="topbar-left">
                <img src="~/Content/images/Logo_atlas.png" alt="Atlas ERP" class="topbar-logo" />
                <div>
                    <div class="page-title">
                        Painel SuperAdmin
                        <span class="super-badge" style="margin-left:10px;">SUPER ADMIN</span>
                    </div>
                    <div class="page-sub">Gerenciamento global do sistema</div>
                </div>
            </div>
            <a href="/Auth/Logout" class="btn-logout">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                Sair
            </a>
        </div>

        <!-- METRICAS -->
        <div class="metrics">
            <div class="metric-card blue">
                <div class="metric-label">Total de Empresas</div>
                <div class="metric-value">@ViewBag.TotalEmpresas</div>
            </div>
            <div class="metric-card green">
                <div class="metric-label">Empresas Ativas</div>
                <div class="metric-value">@ViewBag.EmpresasAtivas</div>
            </div>
            <div class="metric-card gold">
                <div class="metric-label">Pendentes</div>
                <div class="metric-value">@ViewBag.Pendentes</div>
            </div>
            <div class="metric-card red">
                <div class="metric-label">Total de Usuários</div>
                <div class="metric-value">@ViewBag.TotalUsuarios</div>
            </div>
        </div>

        <!-- TABELA -->
        <div class="table-card">
            <div class="table-header">
                <span class="table-title">Todas as Empresas</span>
                <span class="badge-pill">@Model.Count empresa(s)</span>
            </div>

            @if (Model != null && Model.Any())
            {
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>CNPJ</th>
                            <th>E-mail</th>
                            <th>Status</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model)
                        {
                            var statusClass = e.Status?.ToLower() == "ativa" ? "ativa" : "pendente";
                            <tr>
                                <td class="td-muted">#@e.EmpresaId</td>
                                <td><strong>@e.Nome</strong></td>
                                <td class="td-muted">@e.CNPJ</td>
                                <td class="td-muted">@(e.Email ?? "—")</td>
                                <td>
                                    <span class="status-badge @statusClass">
                                        <span class="status-dot"></span>
                                        @(e.Status ?? "Pendente")
                                    </span>
                                </td>
                                <td>
                                    <div class="actions">
                                        @if (e.Status != "Ativa")
                                        {
                                            <form method="POST" action="/SuperAdmin/Aprovar" style="display:inline;">
                                                <input type="hidden" name="empresaId" value="@e.EmpresaId" />
                                                <button type="submit" class="btn-act btn-aprovar">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <polyline points="20 6 9 17 4 12" />
                                                    </svg>
                                                    Aprovar
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form method="POST" action="/SuperAdmin/Rejeitar" style="display:inline;">
                                                <input type="hidden" name="empresaId" value="@e.EmpresaId" />
                                                <button type="submit" class="btn-act btn-rejeitar">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <line x1="18" y1="6" x2="6" y2="18" />
                                                        <line x1="6" y1="6" x2="18" y2="18" />
                                                    </svg>
                                                    Suspender
                                                </button>
                                            </form>
                                        }
                                        <button class="btn-act btn-excluir"
                                                onclick="abrirExcluir('@e.EmpresaId', '@e.Nome')">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="3 6 5 6 21 6" />
                                                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                                <path d="M9 6V4h6v2" />
                                            </svg>
                                            Excluir
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">Nenhuma empresa cadastrada ainda.</div>
            }
        </div>

    </div>

    <!-- MODAL EXCLUIR -->
    <div class="modal-overlay" id="modalExcluir" onclick="fecharFora(event)">
        <div class="modal">
            <button class="modal-close" onclick="fechar()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
            <div class="modal-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="3 6 5 6 21 6" />
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                    <path d="M9 6V4h6v2" />
                </svg>
            </div>
            <div class="modal-title">Excluir empresa?</div>
            <div class="modal-sub" id="excluirNome"></div>
            <div class="modal-warn">Todos os usuários desta empresa serão removidos. Esta ação não pode ser desfeita.</div>
            <form method="POST" action="/SuperAdmin/Excluir">
                <input type="hidden" id="excluirId" name="empresaId" value="" />
                <div class="modal-actions">
                    <button type="button" class="modal-btn-cancel" onclick="fechar()">Cancelar</button>
                    <button type="submit" class="modal-btn-delete">Sim, excluir</button>
                </div>
            </form>
        </div>
    </div>

    <script>function abrirExcluir(id, nome) {
            document.getElementById('excluirId').value         = id;
            document.getElementById('excluirNome').textContent = nome;
            document.getElementById('modalExcluir').classList.add('open');
        }

        function fechar() {
            document.getElementById('modalExcluir').classList.remove('open');
        }

        function fecharFora(e) {
            if (e.target === document.getElementById('modalExcluir')) fechar();
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') fechar();
        });</script>

</body>
</html>