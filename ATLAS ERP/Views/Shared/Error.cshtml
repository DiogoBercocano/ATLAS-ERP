@{
    ViewBag.Title = "Erro - Atlas ERP";
    Layout = null;
    var mensagem = ViewData["Mensagem"]?.ToString() ?? "Ocorreu um erro inesperado.";
    var detalhe = ViewData["Detalhe"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Erro - Atlas ERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: #050d1a;
            color: #e8f0fe;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .bg-dots {
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: radial-gradient(circle, rgba(59,130,246,0.08) 1px, transparent 1px);
            background-size: 40px 40px;
            mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
        }

        .glow {
            position: fixed;
            border-radius: 50%;
            filter: blur(90px);
            pointer-events: none;
        }

        .card {
            position: relative;
            z-index: 1;
            background: #0f1e35;
            border: 1px solid rgba(100,160,255,0.12);
            border-radius: 20px;
            padding: 52px 48px;
            max-width: 480px;
            width: 100%;
            text-align: center;
            animation: fadeUp 0.5s ease both;
        }

        .error-icon {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: rgba(248,113,113,0.10);
            border: 2px solid rgba(248,113,113,0.20);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            color: #f87171;
        }

            .error-icon svg {
                width: 28px;
                height: 28px;
            }

        .error-code {
            font-family: 'Syne', sans-serif;
            font-size: 13px;
            font-weight: 700;
            color: #f87171;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        .error-title {
            font-family: 'Syne', sans-serif;
            font-size: 24px;
            font-weight: 800;
            color: #e8f0fe;
            margin-bottom: 12px;
            line-height: 1.2;
        }

        .error-msg {
            font-size: 14px;
            color: #7a9cc8;
            line-height: 1.6;
            margin-bottom: 32px;
        }

        .error-detail {
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(100,160,255,0.08);
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 12px;
            color: #3d5270;
            font-family: monospace;
            text-align: left;
            margin-bottom: 32px;
            word-break: break-all;
            line-height: 1.5;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #3b82f6;
            color: white;
            text-decoration: none;
            font-family: 'Syne', sans-serif;
            font-size: 14px;
            font-weight: 600;
            padding: 12px 24px;
            border-radius: 10px;
            transition: background 0.2s, transform 0.15s;
            box-shadow: 0 4px 16px rgba(59,130,246,0.25);
        }

            .btn-back:hover {
                background: #2563eb;
                transform: translateY(-1px);
            }

            .btn-back svg {
                width: 15px;
                height: 15px;
            }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="bg-dots"></div>
    <div class="glow" style="width:500px;height:500px;top:-150px;left:-100px;background:rgba(248,113,113,0.08);"></div>
    <div class="glow" style="width:400px;height:400px;bottom:-100px;right:-80px;background:rgba(25,55,130,0.15);"></div>

    <div class="card">
        <div class="error-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
        </div>

        <div class="error-code">Erro 500</div>
        <div class="error-title">Algo deu errado</div>
        <div class="error-msg">@mensagem</div>

        @if (!string.IsNullOrEmpty(detalhe))
        {
            <div class="error-detail">@detalhe</div>
        }

        <a href="/Admin/Dashboard" class="btn-back">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6" />
            </svg>
            Voltar ao Dashboard
        </a>
    </div>

</body>
</html>