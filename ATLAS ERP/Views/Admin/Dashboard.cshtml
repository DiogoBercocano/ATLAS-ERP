@{
    ViewBag.Title = "Dashboard - Atlas ERP";
    Layout = null;

    var vendas = ViewBag.UltimasVendas as List<ATLAS_ERP.Models.Venda>;
    decimal totalHoje = ViewBag.VendasHoje ?? 0;
    int totalProd = ViewBag.TotalProdutos ?? 0;
    int totalCli = ViewBag.TotalClientes ?? 0;
    int totalVendDia = ViewBag.TotalVendasDia ?? 0;

    var empresa = ViewBag.Empresa as ATLAS_ERP.Models.Empresa;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Atlas ERP – Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #050d1a;
            --panel: #0b1525;
            --card: #0f1e35;
            --card-hover: #132540;
            --border: rgba(100,160,255,0.10);
            --border-md: rgba(100,160,255,0.18);
            --accent: #3b82f6;
            --accent-soft: rgba(59,130,246,0.12);
            --accent-glow: rgba(59,130,246,0.22);
            --accent-light: #60a5fa;
            --gold: #c9a84c;
            --gold-soft: rgba(201,168,76,0.12);
            --green: #34d399;
            --green-soft: rgba(52,211,153,0.10);
            --red: #f87171;
            --red-soft: rgba(248,113,113,0.10);
            --text: #e8f0fe;
            --muted: #7a9cc8;
            --faint: #3d5270;
            --sidebar-w: 240px;
            --radius: 14px;
        }

        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            display: flex;
            min-height: 100vh;
        }

        .bg-layer {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .bg-dots {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, rgba(59,130,246,0.10) 1px, transparent 1px);
            background-size: 36px 36px;
            mask-image: radial-gradient(ellipse 70% 70% at 60% 40%, black, transparent);
        }

        .bg-glow-1 {
            position: absolute;
            width: 500px;
            height: 500px;
            top: -120px;
            right: 10%;
            background: rgba(30,60,130,0.20);
            border-radius: 50%;
            filter: blur(90px);
        }

        .bg-glow-2 {
            position: absolute;
            width: 300px;
            height: 300px;
            bottom: -60px;
            left: var(--sidebar-w);
            background: rgba(15,40,100,0.18);
            border-radius: 50%;
            filter: blur(70px);
        }

        /* SIDEBAR */
        .sidebar {
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--panel);
            border-right: 1px solid var(--border);
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            padding: 28px 16px;
            z-index: 100;
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            padding: 0 8px;
            margin-bottom: 36px;
        }

            .sidebar-logo a {
                display: flex;
                align-items: center;
            }

            .sidebar-logo img {
                width: 110px;
                filter: brightness(0) invert(1);
            }

        .sidebar-divider {
            height: 1px;
            background: var(--border);
            margin: 8px 0 16px;
        }

        .menu-label {
            font-size: 10px;
            font-weight: 500;
            color: var(--faint);
            text-transform: uppercase;
            letter-spacing: 0.10em;
            padding: 0 12px;
            margin-bottom: 6px;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--muted);
            text-decoration: none;
            font-size: 14px;
            padding: 10px 12px;
            border-radius: 10px;
            margin-bottom: 2px;
            transition: background 0.18s, color 0.18s;
            position: relative;
            background: none;
            border: none;
            cursor: pointer;
            width: 100%;
            text-align: left;
        }

            .menu-item svg {
                width: 16px;
                height: 16px;
                flex-shrink: 0;
                opacity: 0.7;
                transition: opacity 0.18s;
            }

            .menu-item:hover {
                background: var(--card);
                color: var(--text);
            }

                .menu-item:hover svg {
                    opacity: 1;
                }

            .menu-item.active {
                background: var(--accent-soft);
                color: var(--accent-light);
                font-weight: 500;
            }

                .menu-item.active svg {
                    opacity: 1;
                }

                .menu-item.active::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 20%;
                    bottom: 20%;
                    width: 3px;
                    background: var(--accent);
                    border-radius: 0 3px 3px 0;
                }

            .menu-item.danger {
                color: var(--red);
            }

                .menu-item.danger:hover {
                    background: var(--red-soft);
                    color: var(--red);
                }

        .sidebar-spacer {
            flex: 1;
        }

        .sidebar-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: var(--card);
        }

        .user-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--accent-soft);
            border: 1px solid var(--border-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Syne',sans-serif;
            font-size: 13px;
            font-weight: 700;
            color: var(--accent-light);
            flex-shrink: 0;
        }

        .user-name {
            font-size: 13px;
            font-weight: 500;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-role {
            font-size: 11px;
            color: var(--faint);
        }

        /* MAIN */
        .main {
            margin-left: var(--sidebar-w);
            flex: 1;
            padding: 32px 36px;
            position: relative;
            z-index: 1;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 32px;
        }

        .page-title {
            font-family: 'Syne',sans-serif;
            font-size: 22px;
            font-weight: 700;
        }

        .page-subtitle {
            font-size: 13px;
            color: var(--muted);
            margin-top: 2px;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .date-badge {
            font-size: 12px;
            color: var(--muted);
            background: var(--card);
            border: 1px solid var(--border);
            padding: 7px 14px;
            border-radius: 8px;
        }

        .btn-logout {
            display: flex;
            align-items: center;
            gap: 7px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            color: var(--red);
            background: var(--red-soft);
            border: 1px solid rgba(248,113,113,0.18);
            padding: 8px 14px;
            border-radius: 8px;
            transition: background 0.18s;
        }

            .btn-logout:hover {
                background: rgba(248,113,113,0.18);
            }

            .btn-logout svg {
                width: 14px;
                height: 14px;
            }

        /* METRICAS */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 16px;
            margin-bottom: 24px;
            animation: fadeUp 0.5s ease both;
        }

        .metric-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px 22px;
            position: relative;
            overflow: hidden;
            transition: border-color 0.2s, transform 0.2s;
            cursor: default;
        }

            .metric-card:hover {
                border-color: var(--border-md);
                transform: translateY(-2px);
            }

            .metric-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
            }

            .metric-card.blue::before {
                background: var(--accent);
            }

            .metric-card.gold::before {
                background: var(--gold);
            }

            .metric-card.green::before {
                background: var(--green);
            }

            .metric-card.red::before {
                background: var(--red);
            }

        .metric-icon {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 14px;
        }

            .metric-icon svg {
                width: 16px;
                height: 16px;
            }

            .metric-icon.blue {
                background: var(--accent-soft);
                color: var(--accent-light);
            }

            .metric-icon.gold {
                background: var(--gold-soft);
                color: var(--gold);
            }

            .metric-icon.green {
                background: var(--green-soft);
                color: var(--green);
            }

            .metric-icon.red {
                background: var(--red-soft);
                color: var(--red);
            }

        .metric-label {
            font-size: 11px;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 6px;
        }

        .metric-value {
            font-family: 'Syne',sans-serif;
            font-size: 26px;
            font-weight: 700;
            color: var(--text);
            line-height: 1;
        }

        .metric-sub {
            font-size: 11px;
            color: var(--faint);
            margin-top: 6px;
        }

        /* TABELA */
        .bottom-grid {
            display: grid;
            grid-template-columns: 1fr 280px;
            gap: 18px;
            animation: fadeUp 0.6s ease 0.1s both;
        }

        .table-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
        }

        .table-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 22px 14px;
            border-bottom: 1px solid var(--border);
        }

        .table-title {
            font-family: 'Syne',sans-serif;
            font-size: 15px;
            font-weight: 700;
        }

        .badge-pill {
            font-size: 11px;
            background: var(--accent-soft);
            color: var(--accent-light);
            border: 1px solid rgba(59,130,246,0.2);
            padding: 3px 10px;
            border-radius: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            font-size: 11px;
            color: var(--faint);
            text-transform: uppercase;
            letter-spacing: 0.07em;
            font-weight: 500;
            padding: 10px 22px;
            text-align: left;
            background: rgba(0,0,0,0.15);
        }

        tbody tr {
            border-top: 1px solid var(--border);
            transition: background 0.15s;
        }

            tbody tr:hover {
                background: var(--card-hover);
            }

        tbody td {
            padding: 13px 22px;
            font-size: 14px;
        }

        .td-muted {
            color: var(--muted);
            font-size: 13px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            padding: 3px 10px;
            border-radius: 20px;
        }

            .status-badge.pago {
                background: var(--green-soft);
                color: var(--green);
            }

            .status-badge.pendente {
                background: var(--gold-soft);
                color: var(--gold);
            }

            .status-badge.cancelado {
                background: var(--red-soft);
                color: var(--red);
            }

        .status-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: currentColor;
        }

        .empty-state {
            padding: 40px;
            text-align: center;
            color: var(--faint);
            font-size: 13px;
        }

        /* LATERAL */
        .side-col {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .quick-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 18px;
        }

        .quick-title {
            font-family: 'Syne',sans-serif;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .quick-item {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: var(--muted);
            font-size: 13px;
            padding: 9px 10px;
            border-radius: 8px;
            transition: background 0.15s, color 0.15s;
            margin-bottom: 2px;
        }

            .quick-item svg {
                width: 15px;
                height: 15px;
                flex-shrink: 0;
            }

            .quick-item:hover {
                background: var(--card-hover);
                color: var(--text);
            }

        .alert-card {
            background: var(--gold-soft);
            border: 1px solid rgba(201,168,76,0.20);
            border-radius: var(--radius);
            padding: 16px;
            font-size: 13px;
            color: var(--gold);
            display: flex;
            gap: 10px;
            align-items: flex-start;
            line-height: 1.5;
        }

            .alert-card svg {
                width: 15px;
                height: 15px;
                flex-shrink: 0;
                margin-top: 2px;
            }

        /* MODAL CONFIGURACOES */
        .modal-overlay {
            position: fixed;
            inset: 0;
            z-index: 999;
            background: rgba(0,0,0,0.65);
            backdrop-filter: blur(4px);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

            .modal-overlay.open {
                display: flex;
            }

        .modal {
            background: var(--card);
            border: 1px solid var(--border-md);
            border-radius: 18px;
            padding: 32px 36px;
            width: 100%;
            max-width: 480px;
            position: relative;
            animation: fadeUp 0.25s ease both;
        }

        .modal-close {
            position: absolute;
            top: 16px;
            right: 16px;
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 8px;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--muted);
            transition: background 0.15s, color 0.15s;
        }

            .modal-close:hover {
                background: var(--red-soft);
                color: var(--red);
            }

            .modal-close svg {
                width: 14px;
                height: 14px;
            }

        .modal-title {
            font-family: 'Syne',sans-serif;
            font-size: 17px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .modal-sub {
            font-size: 13px;
            color: var(--muted);
            margin-bottom: 22px;
        }

        .modal-divider {
            height: 1px;
            background: var(--border);
            margin-bottom: 22px;
        }

        /* empresa info no topo do modal */
        .empresa-info {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            border-radius: 10px;
            background: var(--panel);
            border: 1px solid var(--border);
            margin-bottom: 22px;
        }

        .empresa-avatar {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            background: var(--accent-soft);
            border: 1px solid var(--border-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Syne',sans-serif;
            font-size: 16px;
            font-weight: 800;
            color: var(--accent-light);
            flex-shrink: 0;
        }

        .empresa-nome {
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
        }

        .empresa-cnpj {
            font-size: 12px;
            color: var(--faint);
            margin-top: 2px;
        }

        .modal-form-group {
            margin-bottom: 16px;
        }

        .modal-form-label {
            display: block;
            font-size: 11px;
            font-weight: 500;
            color: var(--muted);
            margin-bottom: 7px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .modal-input {
            width: 100%;
            height: 42px;
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 9px;
            padding: 0 14px;
            font-family: 'DM Sans',sans-serif;
            font-size: 14px;
            color: var(--text);
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            -webkit-appearance: none;
        }

            .modal-input::placeholder {
                color: var(--faint);
            }

            .modal-input:hover {
                border-color: var(--border-md);
            }

            .modal-input:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px var(--accent-glow);
            }

        /* upload de logo */
        .upload-area {
            border: 2px dashed var(--border);
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: border-color 0.2s, background 0.2s;
            position: relative;
        }

            .upload-area:hover {
                border-color: var(--accent);
                background: rgba(59,130,246,0.04);
            }

            .upload-area input {
                position: absolute;
                inset: 0;
                opacity: 0;
                cursor: pointer;
                width: 100%;
            }

        .upload-icon {
            color: var(--faint);
            margin-bottom: 8px;
        }

            .upload-icon svg {
                width: 28px;
                height: 28px;
            }

        .upload-text {
            font-size: 13px;
            color: var(--muted);
        }

        .upload-hint {
            font-size: 11px;
            color: var(--faint);
            margin-top: 4px;
        }

        .upload-preview {
            display: none;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 9px;
            background: var(--panel);
            border: 1px solid var(--border);
            margin-top: 10px;
        }

            .upload-preview.visible {
                display: flex;
            }

            .upload-preview img {
                width: 36px;
                height: 36px;
                object-fit: contain;
                border-radius: 6px;
            }

        .upload-preview-name {
            font-size: 13px;
            color: var(--text);
            flex: 1;
        }

        .upload-preview-remove {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--faint);
            padding: 0;
            display: flex;
            transition: color 0.15s;
        }

            .upload-preview-remove:hover {
                color: var(--red);
            }

            .upload-preview-remove svg {
                width: 14px;
                height: 14px;
            }

        .modal-actions {
            display: flex;
            gap: 10px;
            margin-top: 24px;
        }

        .modal-btn-submit {
            flex: 1;
            height: 44px;
            background: var(--accent);
            border: none;
            border-radius: 9px;
            font-family: 'Syne',sans-serif;
            font-size: 14px;
            font-weight: 600;
            color: white;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s;
        }

            .modal-btn-submit:hover {
                background: #2563eb;
                transform: translateY(-1px);
            }

        .modal-btn-cancel {
            height: 44px;
            padding: 0 20px;
            background: none;
            border: 1px solid var(--border);
            border-radius: 9px;
            color: var(--muted);
            font-size: 14px;
            cursor: pointer;
            transition: background 0.15s, color 0.15s;
        }

            .modal-btn-cancel:hover {
                background: var(--card-hover);
                color: var(--text);
            }

        /* sucesso */
        .alert-success {
            background: var(--green-soft);
            border: 1px solid rgba(52,211,153,0.2);
            border-radius: 10px;
            padding: 12px 16px;
            margin-bottom: 16px;
            font-size: 13px;
            color: var(--green);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .alert-success svg {
                width: 14px;
                height: 14px;
                flex-shrink: 0;
            }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width:1100px) {
            .metrics-grid {
                grid-template-columns: repeat(2,1fr);
            }
        }

        @@media (max-width:900px) {
            .bottom-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width:700px) {
            .sidebar {
                display: none;
            }

            .main {
                margin-left: 0;
                padding: 20px;
            }

            .metrics-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <div class="bg-layer">
        <div class="bg-dots"></div>
        <div class="bg-glow-1"></div>
        <div class="bg-glow-2"></div>
    </div>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <a href="/Admin/Dashboard">
                <img src="~/Content/images/Logo_atlas.png" alt="Atlas ERP" />
            </a>
        </div>

        <span class="menu-label">Principal</span>

        <a href="/Admin/Dashboard" class="menu-item active">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7" rx="1" />
                <rect x="14" y="3" width="7" height="7" rx="1" />
                <rect x="3" y="14" width="7" height="7" rx="1" />
                <rect x="14" y="14" width="7" height="7" rx="1" />
            </svg>
            Dashboard
        </a>

        <a href="/Produto" class="menu-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
            </svg>
            Produtos
        </a>

        <a href="/Cliente" class="menu-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
            Clientes
        </a>

        <a href="/Usuario" class="menu-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
                <line x1="19" y1="8" x2="19" y2="14" />
                <line x1="22" y1="11" x2="16" y2="11" />
            </svg>
            Funcionários
        </a>

        <a href="#" class="menu-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="1" x2="12" y2="23" />
                <path d="M17 5H9.5a3.5 3.5 0 1 0 0 7h5a3.5 3.5 0 1 1 0 7H6" />
            </svg>
            Financeiro
        </a>

        <div class="sidebar-divider"></div>
        <span class="menu-label">Sistema</span>

        <!-- CONFIGURACOES — abre modal -->
        <button class="menu-item" onclick="abrirConfig()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3" />
                <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14" />
            </svg>
            Configurações
        </button>

        <a href="/Auth/Logout" class="menu-item danger">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                <polyline points="16 17 21 12 16 7" />
                <line x1="21" y1="12" x2="9" y2="12" />
            </svg>
            Sair
        </a>

        <div class="sidebar-spacer"></div>

        <div class="sidebar-user">
            @{
                var nomeUsuario = Session["UsuarioLogado"]?.ToString() ?? "Usuário";
                var inicial = nomeUsuario.Length > 0 ? nomeUsuario[0].ToString().ToUpper() : "U";
            }
            <div class="user-avatar">@inicial</div>
            <div>
                <div class="user-name">@nomeUsuario</div>
                <div class="user-role">@(Session["Role"]?.ToString() ?? "Usuário")</div>
            </div>
        </div>
    </aside>

    <!-- CONTEUDO -->
    <main class="main">

        <div class="topbar">
            <div>
                <div class="page-title">Dashboard</div>
                <div class="page-subtitle">Visão geral do sistema</div>
            </div>
            <div class="topbar-right">
                <span class="date-badge" id="dataAtual"></span>
                <a href="/Auth/Logout" class="btn-logout">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    Sair
                </a>
            </div>
        </div>

        <!-- METRICAS -->
        <div class="metrics-grid">
            <div class="metric-card blue">
                <div class="metric-icon blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="1" x2="12" y2="23" />
                        <path d="M17 5H9.5a3.5 3.5 0 1 0 0 7h5a3.5 3.5 0 1 1 0 7H6" />
                    </svg>
                </div>
                <div class="metric-label">Vendas Hoje</div>
                <div class="metric-value">R$ @totalHoje.ToString("N2")</div>
                <div class="metric-sub">@totalVendDia venda(s) realizadas</div>
            </div>

            <div class="metric-card gold">
                <div class="metric-icon gold">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                    </svg>
                </div>
                <div class="metric-label">Produtos Cadastrados</div>
                <div class="metric-value">@totalProd</div>
                <div class="metric-sub">no catálogo ativo</div>
            </div>

            <div class="metric-card green">
                <div class="metric-icon green">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                </div>
                <div class="metric-label">Clientes Ativos</div>
                <div class="metric-value">@totalCli</div>
                <div class="metric-sub">cadastrados no sistema</div>
            </div>

            <div class="metric-card red">
                <div class="metric-icon red">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                    </svg>
                </div>
                <div class="metric-label">Pedidos Hoje</div>
                <div class="metric-value">@totalVendDia</div>
                <div class="metric-sub">ordens processadas</div>
            </div>
        </div>

        <!-- TABELA + LATERAL -->
        <div class="bottom-grid">
            <div class="table-card">
                <div class="table-header">
                    <span class="table-title">Últimas Vendas</span>
                    <span class="badge-pill">@(vendas != null ? vendas.Count : 0) registros</span>
                </div>

                @if (vendas != null && vendas.Any())
                {
                    <table>
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Data</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in vendas)
                            {
                                var statusClass = v.Status?.ToLower() == "pago" ? "pago"
                                                : v.Status?.ToLower() == "cancelado" ? "cancelado"
                                                : "pendente";
                                <tr>
                                    <td>@(v.Cliente != null ? v.Cliente.Nome : "—")</td>
                                    <td>R$ @v.Total.ToString("N2")</td>
                                    <td>
                                        <span class="status-badge @statusClass">
                                            <span class="status-dot"></span>
                                            @v.Status
                                        </span>
                                    </td>
                                    <td class="td-muted">@v.DataVenda.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">Nenhuma venda registrada ainda.</div>
                }
            </div>

            <div class="side-col">
                <div class="quick-card">
                    <div class="quick-title">Atalhos Rápidos</div>
                    <a href="/Produto/Create" class="quick-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="16" /><line x1="8" y1="12" x2="16" y2="12" /></svg>
                        Novo Produto
                    </a>
                    <a href="/Cliente/Create" class="quick-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="16" /><line x1="8" y1="12" x2="16" y2="12" /></svg>
                        Novo Cliente
                    </a>
                    <a href="/Usuario/Create" class="quick-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="22" y1="11" x2="16" y2="11" /></svg>
                        Novo Funcionário
                    </a>
                    <a href="/Produto" class="quick-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                        Ver Produtos
                    </a>
                    <a href="/Cliente" class="quick-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                        Ver Clientes
                    </a>
                </div>

                <div class="alert-card">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                        <line x1="12" y1="9" x2="12" y2="13" />
                        <line x1="12" y1="17" x2="12.01" y2="17" />
                    </svg>
                    <span>Verifique produtos com estoque baixo antes de realizar novas vendas.</span>
                </div>
            </div>
        </div>

    </main>

    <!-- MODAL CONFIGURACOES -->
    <div class="modal-overlay" id="modalConfig" onclick="fecharFora(event)">
        <div class="modal">
            <button class="modal-close" onclick="fecharConfig()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>

            <div class="modal-title">Configurações da Empresa</div>
            <div class="modal-sub">Atualize as informações da sua empresa</div>
            <div class="modal-divider"></div>

            @if (ViewBag.ConfigSucesso != null)
            {
                <div class="alert-success">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                    @ViewBag.ConfigSucesso
                </div>
            }

            <!-- info atual da empresa -->
            @if (empresa != null)
            {
                <div class="empresa-info">
                    <div class="empresa-avatar">
                        @(empresa.Nome?.Length > 0 ? empresa.Nome[0].ToString().ToUpper() : "E")
                    </div>
                    <div>
                        <div class="empresa-nome">@empresa.Nome</div>
                        <div class="empresa-cnpj">CNPJ: @empresa.CNPJ</div>
                    </div>
                </div>
            }

            <form method="POST" action="/Empresa/Configuracoes" enctype="multipart/form-data">

                <div class="modal-form-group">
                    <label class="modal-form-label">E-mail da Empresa</label>
                    <input type="email" name="Email" class="modal-input"
                           placeholder="contato@suaempresa.com"
                           value="@(empresa != null ? empresa.Email : "")" />
                </div>

                <div class="modal-form-group">
                    <label class="modal-form-label">Logo da Empresa</label>
                    <div class="upload-area" id="uploadArea">
                        <input type="file" name="Logo" accept="image/*" id="logoInput" onchange="previewLogo(this)" />
                        <div class="upload-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                <polyline points="17 8 12 3 7 8" />
                                <line x1="12" y1="3" x2="12" y2="15" />
                            </svg>
                        </div>
                        <div class="upload-text">Clique para selecionar uma imagem</div>
                        <div class="upload-hint">PNG, JPG ou SVG — máx. 2MB</div>
                    </div>
                    <div class="upload-preview" id="uploadPreview">
                        <img id="previewImg" src="" alt="preview" />
                        <span class="upload-preview-name" id="previewName"></span>
                        <button type="button" class="upload-preview-remove" onclick="removerLogo()">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="18" y1="6" x2="6" y2="18" />
                                <line x1="6" y1="6" x2="18" y2="18" />
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="modal-actions">
                    <button type="button" class="modal-btn-cancel" onclick="fecharConfig()">Cancelar</button>
                    <button type="submit" class="modal-btn-submit">Salvar alterações</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        var d = new Date();
        var opts = { weekday:'short', day:'2-digit', month:'short', year:'numeric' };
        document.getElementById('dataAtual').textContent = d.toLocaleDateString('pt-BR', opts);

        function abrirConfig() {
            document.getElementById('modalConfig').classList.add('open');
        }

        function fecharConfig() {
            document.getElementById('modalConfig').classList.remove('open');
        }

        function fecharFora(e) {
            if (e.target === document.getElementById('modalConfig')) fecharConfig();
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') fecharConfig();
        });

        function previewLogo(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('previewImg').src    = e.target.result;
                    document.getElementById('previewName').textContent = input.files[0].name;
                    document.getElementById('uploadPreview').classList.add('visible');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function removerLogo() {
            document.getElementById('logoInput').value = '';
            document.getElementById('uploadPreview').classList.remove('visible');
        }

        // abrir modal se voltou com sucesso
        @if (ViewBag.ConfigSucesso != null)
        {
            <text>window.onload = function() { abrirConfig(); };</text>
        }
    </script>

</body>
</html>