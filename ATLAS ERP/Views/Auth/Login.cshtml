@{
    ViewBag.Title = "Login - Atlas ERP";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Atlas ERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --navy: #050d1a;
            --panel: #0b1525;
            --card: #0f1e35;
            --border: rgba(100,160,255,0.12);
            --border-hover: rgba(100,160,255,0.28);
            --accent: #3b82f6;
            --accent-glow: rgba(59,130,246,0.18);
            --accent-light: #60a5fa;
            --gold: #c9a84c;
            --text-primary: #e8f0fe;
            --text-secondary: #7a9cc8;
            --text-muted: #3d5270;
            --danger: #f87171;
            --danger-bg: rgba(248,113,113,0.08);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background-color: var(--navy);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        .bg-canvas {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
        }

        .grid-dot {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, rgba(59,130,246,0.10) 1px, transparent 1px);
            background-size: 40px 40px;
            mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
        }

        .glow-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
        }

        .geo-circle {
            position: absolute;
            border-radius: 50%;
            border: 1px solid rgba(59,130,246,0.05);
        }

        .page-wrapper {
            position: relative;
            z-index: 1;
            display: flex;
            width: 100%;
            max-width: 1020px;
            min-height: 520px;
            padding: 1rem;
            gap: 0;
            animation: fadeUp 0.7s ease both;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(24px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* PAINEL ESQUERDO */
        .brand-panel {
            flex: 1;
            background: var(--panel);
            border: 1px solid var(--border);
            border-right: none;
            border-radius: 24px 0 0 24px;
            padding: 36px 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

            .brand-panel::before {
                content: '';
                position: absolute;
                top: -80px;
                right: -80px;
                width: 300px;
                height: 300px;
                border-radius: 50%;
                border: 1px solid rgba(59,130,246,0.08);
            }

            .brand-panel::after {
                content: '';
                position: absolute;
                bottom: -60px;
                left: -60px;
                width: 220px;
                height: 220px;
                border-radius: 50%;
                border: 1px solid rgba(59,130,246,0.06);
            }

        .brand-accent-line {
            position: absolute;
            left: 0;
            top: 15%;
            bottom: 15%;
            width: 2px;
            background: linear-gradient(to bottom, transparent, var(--gold), transparent);
            opacity: 0.4;
        }

        .brand-logo-wrap {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

            .brand-logo-wrap img {
                width: 260px;
                max-width: 100%;
                filter: drop-shadow(0 0 30px rgba(59,130,246,0.18));
            }

        .brand-bottom {
            position: relative;
            z-index: 1;
            width: 100%;
        }

        .brand-tagline {
            font-family: 'Syne', sans-serif;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.14em;
            text-align: center;
            margin-bottom: 16px;
        }

        .brand-features {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .brand-feature {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            background: rgba(59,130,246,0.04);
            border: 1px solid rgba(59,130,246,0.08);
            border-radius: 10px;
        }

        .feature-icon {
            width: 28px;
            height: 28px;
            border-radius: 7px;
            background: rgba(59,130,246,0.10);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            color: var(--accent-light);
        }

            .feature-icon svg {
                width: 13px;
                height: 13px;
            }

        .feature-text {
            font-size: 12px;
            color: var(--text-secondary);
            line-height: 1.4;
        }

            .feature-text strong {
                display: block;
                font-size: 12px;
                font-weight: 500;
                color: var(--text-primary);
                margin-bottom: 1px;
            }

        .panel-divider {
            width: 1px;
            background: linear-gradient(to bottom, transparent, var(--border), var(--border), transparent);
            flex-shrink: 0;
        }

        /* PAINEL DIREITO */
        .login-panel {
            width: 380px;
            flex-shrink: 0;
            background: var(--card);
            border: 1px solid var(--border);
            border-left: none;
            border-radius: 0 24px 24px 0;
            padding: 36px 38px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(59,130,246,0.08);
            border: 1px solid rgba(59,130,246,0.15);
            border-radius: 20px;
            padding: 4px 12px;
            font-size: 10px;
            color: var(--accent-light);
            letter-spacing: 0.06em;
            margin-bottom: 20px;
            align-self: flex-start;
        }

        .login-badge-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--accent-light);
        }

        .login-title {
            font-family: 'Syne', sans-serif;
            font-size: 24px;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 6px;
            line-height: 1.1;
        }

        .login-subtitle {
            font-size: 13px;
            color: var(--text-secondary);
            margin-bottom: 24px;
            line-height: 1.5;
        }

        .alert-error {
            background: var(--danger-bg);
            border: 1px solid rgba(248,113,113,0.2);
            border-radius: 10px;
            padding: 10px 14px;
            margin-bottom: 16px;
            font-size: 13px;
            color: var(--danger);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .alert-error svg {
                width: 14px;
                height: 14px;
                flex-shrink: 0;
            }

        .form-group {
            margin-bottom: 16px;
        }

        .form-label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 7px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            pointer-events: none;
            display: flex;
        }

            .input-icon svg {
                width: 15px;
                height: 15px;
            }

        .form-control {
            width: 100%;
            height: 44px;
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 0 14px 0 44px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            color: var(--text-primary);
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            -webkit-appearance: none;
        }

            .form-control::placeholder {
                color: var(--text-muted);
            }

            .form-control:hover {
                border-color: var(--border-hover);
            }

            .form-control:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px var(--accent-glow);
            }

        .toggle-pass {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            padding: 0;
            display: flex;
            transition: color 0.2s;
        }

            .toggle-pass:hover {
                color: var(--accent-light);
            }

            .toggle-pass svg {
                width: 15px;
                height: 15px;
            }

        .password-input {
            padding-right: 44px;
        }

        .form-footer-row {
            display: flex;
            justify-content: flex-end;
            margin-top: -8px;
            margin-bottom: 8px;
        }

        .link-muted {
            font-size: 12px;
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.2s;
        }

            .link-muted:hover {
                color: var(--accent-light);
            }

        .btn-submit {
            width: 100%;
            height: 46px;
            background: var(--accent);
            border: none;
            border-radius: 10px;
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            font-weight: 700;
            color: white;
            cursor: pointer;
            margin-top: 4px;
            letter-spacing: 0.04em;
            transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
            box-shadow: 0 4px 20px rgba(59,130,246,0.30);
            position: relative;
            overflow: hidden;
        }

            .btn-submit::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, transparent 60%);
                pointer-events: none;
            }

            .btn-submit:hover {
                background: #2563eb;
                transform: translateY(-1px);
                box-shadow: 0 6px 28px rgba(59,130,246,0.40);
            }

            .btn-submit:active {
                transform: translateY(0);
            }

        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 20px 0;
        }

        .divider-line {
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .divider-text {
            font-size: 11px;
            color: var(--text-muted);
            letter-spacing: 0.06em;
        }

        .cadastro-link {
            text-align: center;
            font-size: 13px;
            color: var(--text-secondary);
        }

            .cadastro-link a {
                color: var(--accent-light);
                text-decoration: none;
                font-weight: 600;
                transition: opacity 0.2s;
            }

                .cadastro-link a:hover {
                    opacity: 0.8;
                }

        .version-tag {
            text-align: center;
            font-size: 11px;
            color: var(--text-muted);
            letter-spacing: 0.04em;
            margin-top: 20px;
        }

        @@media (max-width: 800px) {
            .brand-panel {
                display: none;
            }

            .panel-divider {
                display: none;
            }

            .login-panel {
                width: 100%;
                border-radius: 24px;
                border-left: 1px solid var(--border);
                max-width: 400px;
            }
        }
    </style>
</head>
<body>

    <div class="bg-canvas">
        <div class="grid-dot"></div>
        <div class="glow-orb" style="width:600px;height:600px;top:-150px;left:-100px;background:rgba(25,55,130,0.20);"></div>
        <div class="glow-orb" style="width:400px;height:400px;bottom:-80px;right:-60px;background:rgba(15,40,100,0.18);"></div>
        <div class="geo-circle" style="width:700px;height:700px;top:-200px;right:-250px;"></div>
        <div class="geo-circle" style="width:400px;height:400px;bottom:-100px;left:-150px;"></div>
    </div>

    <div class="page-wrapper">

        <div class="brand-panel">
            <div class="brand-accent-line"></div>

            <div class="brand-logo-wrap">
                <img src="~/Content/images/logos/atlas_erp_diamante.svg" alt="Atlas ERP" />
            </div>

            <div class="brand-bottom">
                <div class="brand-tagline">Gestão comercial inteligente</div>
                <div class="brand-features">
                    <div class="brand-feature">
                        <div class="feature-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                            </svg>
                        </div>
                        <div class="feature-text">
                            <strong>Multiempresa seguro</strong>
                            Dados isolados por empresa
                        </div>
                    </div>
                    <div class="brand-feature">
                        <div class="feature-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                            </svg>
                        </div>
                        <div class="feature-text">
                            <strong>Tempo real</strong>
                            Vendas e estoque integrados
                        </div>
                    </div>
                    <div class="brand-feature">
                        <div class="feature-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                <circle cx="9" cy="7" r="4" />
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                            </svg>
                        </div>
                        <div class="feature-text">
                            <strong>Multi-usuário</strong>
                            Permissões por função
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="panel-divider"></div>

        <div class="login-panel">

            <div class="login-badge">
                <span class="login-badge-dot"></span>
                SISTEMA ATIVO
            </div>

            <h1 class="login-title">Bem-vindo<br />de volta.</h1>
            <p class="login-subtitle">Acesse sua conta para continuar gerenciando seu negócio.</p>

            @if (ViewBag.Erro != null)
            {
                <div class="alert-error">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                    @ViewBag.Erro
                </div>
            }

            @using (Html.BeginForm("Login", "Auth", FormMethod.Post))
            {
                <div class="form-group">
                    <label class="form-label">E-mail</label>
                    <div class="input-wrapper">
                        <input type="email" name="email" class="form-control"
                               placeholder="seu@email.com" required autocomplete="email" />
                        <span class="input-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="2" y="4" width="20" height="16" rx="2" />
                                <path d="m2 7 10 7L22 7" />
                            </svg>
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Senha</label>
                    <div class="input-wrapper">
                        <input type="password" name="senha" id="senhaInput"
                               class="form-control password-input"
                               placeholder="••••••••" required autocomplete="current-password" />
                        <span class="input-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                        </span>
                        <button type="button" class="toggle-pass" onclick="toggleSenha()">
                            <svg id="eyeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="form-footer-row">
                    <a href="#" class="link-muted">Esqueci minha senha</a>
                </div>

                <button type="submit" class="btn-submit">Entrar no sistema</button>
            }

            <div class="divider">
                <div class="divider-line"></div>
                <span class="divider-text">OU</span>
                <div class="divider-line"></div>
            </div>

            <div class="cadastro-link">
                Não tem acesso?
                <a href="/Empresa/Cadastro">Cadastrar minha empresa</a>
            </div>

            <div class="version-tag">ATLAS ERP &nbsp;·&nbsp; v1.0 &nbsp;·&nbsp; Sistema Comercial</div>
        </div>

    </div>

    <script>
        function toggleSenha() {
            var input = document.getElementById('senhaInput');
            var icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
            } else {
                input.type = 'password';
                icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
            }
        }
    </script>
</body>
</html>