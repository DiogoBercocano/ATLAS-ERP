@model ATLAS_ERP.Models.Cliente
@{
    ViewBag.Title = "Novo Cliente - Atlas ERP";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Atlas ERP – Novo Cliente</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #050d1a;
            --panel: #0b1525;
            --card: #0f1e35;
            --card-hover: #132540;
            --border: rgba(100,160,255,0.10);
            --border-md: rgba(100,160,255,0.18);
            --accent: #3b82f6;
            --accent-soft: rgba(59,130,246,0.12);
            --accent-glow: rgba(59,130,246,0.20);
            --accent-light: #60a5fa;
            --gold: #c9a84c;
            --red: #f87171;
            --red-soft: rgba(248,113,113,0.10);
            --text: #e8f0fe;
            --muted: #7a9cc8;
            --faint: #3d5270;
            --sidebar-w: 320px;
            --radius: 14px;
        }

        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            display: flex;
            min-height: 100vh;
        }

        .bg-layer {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .bg-dots {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, rgba(59,130,246,0.10) 1px, transparent 1px);
            background-size: 36px 36px;
            mask-image: radial-gradient(ellipse 70% 70% at 60% 40%, black, transparent);
        }

        .bg-glow {
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
        }

        /* SIDEBAR */
        .sidebar {
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--panel);
            border-right: 1px solid var(--border);
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            padding: 28px 16px;
            z-index: 100;
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0;
            margin-bottom: 36px;
        }

            .sidebar-logo a {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 100%;
            }

            .sidebar-logo img {
                width: 300px;
                max-width: 100%;
            }

        .sidebar-divider {
            height: 1px;
            background: var(--border);
            margin: 8px 0 16px;
        }

        .menu-label {
            font-size: 10px;
            font-weight: 500;
            color: var(--faint);
            text-transform: uppercase;
            letter-spacing: 0.10em;
            padding: 0 12px;
            margin-bottom: 6px;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--muted);
            text-decoration: none;
            font-size: 14px;
            padding: 10px 12px;
            border-radius: 10px;
            margin-bottom: 2px;
            transition: background 0.18s, color 0.18s;
            position: relative;
        }

            .menu-item svg {
                width: 16px;
                height: 16px;
                flex-shrink: 0;
                opacity: 0.7;
            }

            .menu-item:hover {
                background: var(--card);
                color: var(--text);
            }

                .menu-item:hover svg {
                    opacity: 1;
                }

            .menu-item.active {
                background: var(--accent-soft);
                color: var(--accent-light);
                font-weight: 500;
            }

                .menu-item.active svg {
                    opacity: 1;
                }

                .menu-item.active::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 20%;
                    bottom: 20%;
                    width: 3px;
                    background: var(--accent);
                    border-radius: 0 3px 3px 0;
                }

            .menu-item.danger {
                color: var(--red);
            }

                .menu-item.danger:hover {
                    background: var(--red-soft);
                }

        .sidebar-spacer {
            flex: 1;
        }

        .sidebar-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: var(--card);
        }

        .user-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--accent-soft);
            border: 1px solid var(--border-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Syne', sans-serif;
            font-size: 13px;
            font-weight: 700;
            color: var(--accent-light);
            flex-shrink: 0;
        }

        .user-name {
            font-size: 13px;
            font-weight: 500;
            color: var(--text);
        }

        .user-role {
            font-size: 11px;
            color: var(--faint);
        }

        /* MAIN */
        .main {
            margin-left: var(--sidebar-w);
            flex: 1;
            padding: 32px 40px;
            position: relative;
            z-index: 1;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
        }

        .page-title {
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 700;
        }

        .page-subtitle {
            font-size: 13px;
            color: var(--muted);
            margin-top: 2px;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            color: var(--muted);
            text-decoration: none;
            font-size: 13px;
            background: var(--card);
            border: 1px solid var(--border);
            padding: 9px 16px;
            border-radius: 10px;
            transition: background 0.18s, color 0.18s;
        }

            .btn-back:hover {
                background: var(--card-hover);
                color: var(--text);
            }

            .btn-back svg {
                width: 14px;
                height: 14px;
            }

        /* FORM */
        .form-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 32px 36px;
            max-width: 640px;
            animation: fadeUp 0.5s ease both;
        }

        .form-section-title {
            font-family: 'Syne', sans-serif;
            font-size: 12px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 18px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border);
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-row-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .form-label {
            display: block;
            font-size: 11px;
            font-weight: 500;
            color: var(--muted);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--faint);
            pointer-events: none;
            display: flex;
        }

            .input-icon svg {
                width: 14px;
                height: 14px;
            }

        .form-control {
            width: 100%;
            height: 44px;
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 0 14px 0 40px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            color: var(--text);
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            -webkit-appearance: none;
        }

            .form-control::placeholder {
                color: var(--faint);
            }

            .form-control:hover {
                border-color: var(--border-md);
            }

            .form-control:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px var(--accent-glow);
            }

        select.form-control {
            cursor: pointer;
        }

        .form-divider {
            height: 1px;
            background: var(--border);
            margin: 24px 0;
        }

        .form-actions {
            display: flex;
            gap: 12px;
            margin-top: 28px;
        }

        .btn-submit {
            flex: 1;
            height: 48px;
            background: var(--accent);
            border: none;
            border-radius: 10px;
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            font-weight: 600;
            color: white;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s;
            box-shadow: 0 4px 16px rgba(59,130,246,0.25);
        }

            .btn-submit:hover {
                background: #2563eb;
                transform: translateY(-1px);
            }

        .btn-cancel {
            height: 48px;
            padding: 0 24px;
            background: none;
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--muted);
            font-size: 14px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            transition: background 0.15s, color 0.15s;
        }

            .btn-cancel:hover {
                background: var(--card-hover);
                color: var(--text);
            }

        .field-error {
            font-size: 12px;
            color: var(--red);
            margin-top: 5px;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 700px) {
            .sidebar {
                display: none;
            }

            .main {
                margin-left: 0;
                padding: 20px;
            }

            .form-row-2 {
                grid-template-columns: 1fr;
            }

            .form-card {
                padding: 24px;
            }
        }
    </style>
</head>
<body>

    <div class="bg-layer">
        <div class="bg-dots"></div>
        <div class="bg-glow" style="width:400px;height:400px;top:-100px;right:5%;background:rgba(30,60,130,0.18);"></div>
    </div>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <a href="/Admin/Dashboard">
                <img src="~/Content/images/logos/atlas_erp_diamante.svg" alt="Atlas ERP" />
            </a>
        </div>

        <span class="menu-label">Principal</span>

        <a href="/Admin/Dashboard" class="menu-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7" rx="1" />
                <rect x="14" y="3" width="7" height="7" rx="1" />
                <rect x="3" y="14" width="7" height="7" rx="1" />
                <rect x="14" y="14" width="7" height="7" rx="1" />
            </svg>
            Dashboard
        </a>

        <a href="/Produto" class="menu-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
            </svg>
            Produtos
        </a>

        <a href="/Cliente" class="menu-item active">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
            Clientes
        </a>

        <a href="/Usuario" class="menu-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
                <line x1="19" y1="8" x2="19" y2="14" />
                <line x1="22" y1="11" x2="16" y2="11" />
            </svg>
            Funcionários
        </a>

        <a href="#" class="menu-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="1" x2="12" y2="23" />
                <path d="M17 5H9.5a3.5 3.5 0 1 0 0 7h5a3.5 3.5 0 1 1 0 7H6" />
            </svg>
            Financeiro
        </a>

        <div class="sidebar-divider"></div>
        <span class="menu-label">Sistema</span>

        <a href="/Auth/Logout" class="menu-item danger">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                <polyline points="16 17 21 12 16 7" />
                <line x1="21" y1="12" x2="9" y2="12" />
            </svg>
            Sair
        </a>

        <div class="sidebar-spacer"></div>

        <div class="sidebar-user">
            @{
                var nomeUsuario = Session["UsuarioLogado"]?.ToString() ?? "Usuário";
                var inicial = nomeUsuario.Length > 0 ? nomeUsuario[0].ToString().ToUpper() : "U";
            }
            <div class="user-avatar">@inicial</div>
            <div>
                <div class="user-name">@nomeUsuario</div>
                <div class="user-role">@(Session["Role"]?.ToString() ?? "Usuário")</div>
            </div>
        </div>
    </aside>

    <!-- CONTEUDO -->
    <main class="main">

        <div class="topbar">
            <div>
                <div class="page-title">Novo Cliente</div>
                <div class="page-subtitle">Preencha os dados para cadastrar</div>
            </div>
            <a href="/Cliente" class="btn-back">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="15 18 9 12 15 6" />
                </svg>
                Voltar
            </a>
        </div>

        <div class="form-card">

            @using (Html.BeginForm("Create", "Cliente", FormMethod.Post))
            {
                <div class="form-section-title">Dados Pessoais</div>

                <div class="form-group">
                    <label class="form-label">Nome completo</label>
                    <div class="input-wrap">
                        @Html.TextBoxFor(m => m.Nome, new { @class = "form-control", placeholder = "Nome do cliente" })
                        <span class="input-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                        </span>
                    </div>
                    @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "field-error" })
                </div>

                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label">Documento (CPF/CNPJ)</label>
                        <div class="input-wrap">
                            @Html.TextBoxFor(m => m.Documento, new { @class = "form-control", placeholder = "000.000.000-00", id = "docInput" })
                            <span class="input-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                    <polyline points="14 2 14 8 20 8" />
                                </svg>
                            </span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Telefone</label>
                        <div class="input-wrap">
                            @Html.TextBoxFor(m => m.Telefone, new { @class = "form-control", placeholder = "(00) 00000-0000", id = "telInput" })
                            <span class="input-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.8a16 16 0 0 0 6.29 6.29l.95-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                                </svg>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">E-mail</label>
                    <div class="input-wrap">
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "cliente@email.com", type = "email" })
                        <span class="input-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="2" y="4" width="20" height="16" rx="2" />
                                <path d="m2 7 10 7L22 7" />
                            </svg>
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Endereço</label>
                    <div class="input-wrap">
                        @Html.TextBoxFor(m => m.Endereco, new { @class = "form-control", placeholder = "Rua, número, bairro, cidade - UF" })
                        <span class="input-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                <circle cx="12" cy="10" r="3" />
                            </svg>
                        </span>
                    </div>
                </div>

                <div class="form-divider"></div>
                <div class="form-section-title">Informações Comerciais</div>

                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label">Limite de Crédito (R$)</label>
                        <div class="input-wrap">
                            @Html.TextBoxFor(m => m.LimiteCredito, new { @class = "form-control", placeholder = "0,00", type = "number", step = "0.01", min = "0" })
                            <span class="input-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="12" y1="1" x2="12" y2="23" />
                                    <path d="M17 5H9.5a3.5 3.5 0 1 0 0 7h5a3.5 3.5 0 1 1 0 7H6" />
                                </svg>
                            </span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <div class="input-wrap">
                            @Html.DropDownListFor(m => m.Ativo,
                                new SelectList(new[] {
                                    new { Value = "true",  Text = "Ativo" },
                                    new { Value = "false", Text = "Inativo" }
                                }, "Value", "Text"),
                                new { @class = "form-control" }
                            )
                            <span class="input-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10" />
                                    <polyline points="12 6 12 12 16 14" />
                                </svg>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <a href="/Cliente" class="btn-cancel">Cancelar</a>
                    <button type="submit" class="btn-submit">Cadastrar Cliente</button>
                </div>
            }
        </div>
    </main>

    <script>
        document.getElementById('docInput').addEventListener('input', function(e) {
            var v = e.target.value.replace(/\D/g, '');
            if (v.length <= 11) {
                v = v.replace(/(\d{3})(\d)/, '$1.$2');
                v = v.replace(/(\d{3})(\d)/, '$1.$2');
                v = v.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
            } else {
                v = v.replace(/^(\d{2})(\d)/, '$1.$2');
                v = v.replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3');
                v = v.replace(/\.(\d{3})(\d)/, '.$1/$2');
                v = v.replace(/(\d{4})(\d)/, '$1-$2');
            }
            e.target.value = v;
        });

        document.getElementById('telInput').addEventListener('input', function(e) {
            var v = e.target.value.replace(/\D/g, '');
            v = v.replace(/^(\d{2})(\d)/, '($1) $2');
            v = v.replace(/(\d{5})(\d)/, '$1-$2');
            e.target.value = v;
        });
    </script>

</body>
</html>